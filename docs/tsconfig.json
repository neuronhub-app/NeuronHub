// this must stay a subset of [[client/tsconfig.json]]
{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",

    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true, // needed because of broken @types/mdx

    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    // from react-router docs
    "rootDirs": [".", "./.react-router/types"],

    "paths": {
      "@/e2e/*": ["./e2e/*"],
      "@/*": ["./src/*"],
      "#chakra-internal/*": ["./node_modules/@chakra-ui/react/dist/types/styled-system/*"], // #122
      "~/react-router/*": ["./.react-router/types/src/apps/*"],
    },
  },
  "include": [
    "src",
    "e2e",
    "scripts",
    "vite.config.ts",
    ".chakra/types",
    // from react-router docs
    "./.react-router/types",
  ],
}
