// this must stay a subset of [[client/tsconfig.json]]
{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",

    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true, // for the broken @types/mdx

    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    "rootDirs": [".", "./.react-router/types"], // from react-router docs

    "paths": {
      "@/e2e/*": ["./e2e/*"],
      "@/*": ["./src/*"],
      "~/react-router/*": ["./.react-router/types/src/apps/*"],
    },
  },
  "include": [
    "src",
    "e2e",
    "scripts",
    "vite.config.ts",
    "./.react-router/types", // from react-router doc
  ],
}
