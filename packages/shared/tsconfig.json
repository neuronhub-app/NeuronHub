// this must stay a subset of [[client/tsconfig.json]]
{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",

    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    "paths": {
      "@neuronhub/shared/*": ["./src/*"],
      "#chakra-internal/*": ["./node_modules/@chakra-ui/react/dist/types/styled-system/*"], // #122
    },
  },
  "include": ["src", ".chakra/types"],
}
