// this must stay a subset of [[client/tsconfig.json]]
{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",

    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    "paths": {
      "@neuronhub/shared/*": ["./src/*"],
    },
  },
  "include": ["src"],
}
